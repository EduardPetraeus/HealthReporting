# =============================================================================
# .env.example — Health Reporting Platform
#
# Copy this file to ~/.config/health_reporting/.env and fill in real values.
# Never commit the actual .env file — it is gitignored.
#
# Databricks credentials for CI/CD live in GitHub Secrets, not here.
# Local Databricks auth uses ~/.databrickscfg (managed by Databricks CLI).
# =============================================================================

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------
HEALTH_ENV=dev                        # dev | prd

# -----------------------------------------------------------------------------
# Oura connector
# Register app at: https://cloud.ouraring.com/oauth/applications
# -----------------------------------------------------------------------------
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
OURA_REDIRECT_URI=http://localhost:8000/callback   # default, change if needed

# -----------------------------------------------------------------------------
# Data lake paths (local Mac Mini)
# -----------------------------------------------------------------------------
OURA_DATA_LAKE_ROOT=/Users/Shared/data_lake/oura/raw

# -----------------------------------------------------------------------------
# Withings connector (not yet implemented — placeholder)
# Register app at: https://developer.withings.com
# -----------------------------------------------------------------------------
# WITHINGS_CLIENT_ID=your_withings_client_id
# WITHINGS_CLIENT_SECRET=your_withings_client_secret
# WITHINGS_ACCESS_TOKEN=your_withings_access_token
# WITHINGS_REFRESH_TOKEN=your_withings_refresh_token

# -----------------------------------------------------------------------------
# Strava connector (not yet implemented — placeholder)
# Register app at: https://www.strava.com/settings/api
# -----------------------------------------------------------------------------
# STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET=your_strava_client_secret
# STRAVA_ACCESS_TOKEN=your_strava_access_token
# STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# -----------------------------------------------------------------------------
# Databricks (local dev only — CI/CD uses GitHub Secrets)
# Managed via ~/.databrickscfg. Set here only if not using CLI profile.
# -----------------------------------------------------------------------------
# DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
# DATABRICKS_TOKEN=your_databricks_pat_token
