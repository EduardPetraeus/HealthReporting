<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.health.api-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/clauseduardpetraeus/HealthReporting/.venv-ai/bin/uvicorn</string>
        <string>health_platform.api.server:app</string>
        <string>--host</string>
        <string>0.0.0.0</string>
        <string>--port</string>
        <string>8000</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/clauseduardpetraeus/HealthReporting/health_unified_platform</string>

    <key>EnvironmentVariables</key>
    <dict>
